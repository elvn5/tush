# ─────────────────────────────────────────────────────────────────────────────
# Android release build — signing configuration
# Copy this file to .env.android (already in .gitignore) and fill in values.
# ─────────────────────────────────────────────────────────────────────────────

# Base64-encoded keystore file.
# Generate with:
#   base64 -w 0 your-release-key.jks > keystore.b64
#   cat keystore.b64   # paste the output below
KEYSTORE_FILE_BASE64=

# Keystore password (set when the keystore was created)
KEYSTORE_PASSWORD=

# Key alias inside the keystore
KEY_ALIAS=

# Key password (may differ from KEYSTORE_PASSWORD)
KEY_PASSWORD=

# API URL baked into the app via --dart-define at build time
API_URL=https://your-production-server.com
